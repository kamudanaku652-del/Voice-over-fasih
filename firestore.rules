rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Hardened isAdmin with Bootstrapped Admin support
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'twentyonetiktok55@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. Entity Blueprints
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.subscriptionTier in ['free', 'premium'] &&
             data.role in ['user', 'admin'] &&
             data.usageCount is int &&
             (data.trialStartDate == null || data.trialStartDate is string) &&
             data.createdAt is timestamp;
    }
    
    function isValidEdit(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.effects is map &&
             data.createdAt is timestamp;
    }

    // 4. Collections
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Prevent query scraping by enforcing UID check in list
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (
                        // Allow specific dev email to bootstrap as admin/premium
                        (request.auth.token.email == 'twentyonetiktok55@gmail.com' && request.auth.token.email_verified == true)
                        || 
                        // Everyone else starts as user/free
                        (incoming().role == 'user' && incoming().subscriptionTier == 'free')
                      ) &&
                      incoming().usageCount == 0 &&
                      incoming().createdAt == request.time;

      allow update: if (
        (isOwner(userId) && 
         isValidUser(incoming()) && 
         // User cannot change their own role or subscription status
         incoming().role == existing().role &&
         incoming().subscriptionTier == existing().subscriptionTier &&
         incoming().createdAt == existing().createdAt &&
         // Allowed fields for regular user update
         incoming().diff(existing()).affectedKeys().hasOnly(['email', 'trialStartDate', 'usageCount']))
        || 
        (isAdmin() && 
         isValidUser(incoming()) &&
         incoming().uid == existing().uid &&
         incoming().role == existing().role &&
         incoming().createdAt == existing().createdAt &&
         // Admin can change status and usage
         incoming().diff(existing()).affectedKeys().hasOnly(['subscriptionTier', 'usageCount']))
      );
      
      allow delete: if false; // Profiles cannot be deleted via client

      // Subcollection for voice edits
      match /edits/{editId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidEdit(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidEdit(incoming()) && 
                        incoming().createdAt == existing().createdAt &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'effects']);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
